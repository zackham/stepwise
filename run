#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

API_PORT="${STEPWISE_PORT:-8340}"
WEB_PORT="${STEPWISE_WEB_PORT:-5173}"
DB_PATH="${STEPWISE_DB:-$SCRIPT_DIR/stepwise.db}"
TEMPLATES_DIR="${STEPWISE_TEMPLATES:-$SCRIPT_DIR/templates}"
PID_DIR="$SCRIPT_DIR/.pids"

_ensure_deps() {
    if [ ! -d ".venv" ] || [ ! -f ".venv/bin/python" ]; then
        echo "Installing Python dependencies..."
        uv sync
    fi
    if [ ! -d "web/node_modules" ]; then
        echo "Installing web dependencies..."
        (cd web && npm install)
    fi
}

_start_api() {
    mkdir -p "$PID_DIR" "$TEMPLATES_DIR"
    echo "Starting API server on port $API_PORT..."
    STEPWISE_DB="$DB_PATH" STEPWISE_TEMPLATES="$TEMPLATES_DIR" STEPWISE_PORT="$API_PORT" \
        uv run python -m stepwise.server &
    echo $! > "$PID_DIR/api.pid"
    echo "  API PID: $(cat "$PID_DIR/api.pid")"
}

_start_web() {
    mkdir -p "$PID_DIR"
    echo "Starting web dev server on port $WEB_PORT..."
    (cd web && VITE_API_URL="http://localhost:$API_PORT" npx vite --port "$WEB_PORT" --host) &
    echo $! > "$PID_DIR/web.pid"
    echo "  Web PID: $(cat "$PID_DIR/web.pid")"
}

_stop() {
    echo "Stopping Stepwise..."
    for pidfile in "$PID_DIR"/*.pid; do
        [ -f "$pidfile" ] || continue
        pid=$(cat "$pidfile")
        name=$(basename "$pidfile" .pid)
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            echo "  Stopped $name (PID $pid)"
        else
            echo "  $name already stopped"
        fi
        rm -f "$pidfile"
    done
    # Also kill any orphan processes
    pkill -f "stepwise.server" 2>/dev/null || true
    pkill -f "vite.*--port.*$WEB_PORT" 2>/dev/null || true
}

_status() {
    echo "Stepwise Status:"
    for pidfile in "$PID_DIR"/*.pid; do
        [ -f "$pidfile" ] || continue
        pid=$(cat "$pidfile")
        name=$(basename "$pidfile" .pid)
        if kill -0 "$pid" 2>/dev/null; then
            echo "  ✓ $name running (PID $pid)"
        else
            echo "  ✗ $name stopped (stale PID $pid)"
            rm -f "$pidfile"
        fi
    done
    if [ ! -d "$PID_DIR" ] || [ -z "$(ls -A "$PID_DIR" 2>/dev/null)" ]; then
        echo "  No services running"
    fi
}

_build() {
    echo "Building web app for production..."
    (cd web && npm run build)
    echo "Built to web/dist/"
}

_test() {
    echo "Running Python tests..."
    uv run pytest -v
    echo ""
    echo "Running web tests..."
    (cd web && npx vitest run 2>/dev/null || echo "No web tests configured yet")
}

_logs() {
    echo "Tailing logs (Ctrl+C to stop)..."
    tail -f "$SCRIPT_DIR"/.pids/*.log 2>/dev/null || echo "No log files found"
}

case "${1:-help}" in
    start)
        _ensure_deps
        _stop 2>/dev/null || true
        _start_api
        sleep 1
        _start_web
        echo ""
        echo "Stepwise is running:"
        echo "  API:  http://localhost:$API_PORT"
        echo "  Web:  http://localhost:$WEB_PORT"
        echo "  Docs: http://localhost:$API_PORT/docs"
        ;;
    stop)
        _stop
        ;;
    restart)
        _stop 2>/dev/null || true
        sleep 1
        _ensure_deps
        _start_api
        sleep 1
        _start_web
        echo ""
        echo "Stepwise restarted:"
        echo "  API:  http://localhost:$API_PORT"
        echo "  Web:  http://localhost:$WEB_PORT"
        ;;
    status)
        _status
        ;;
    build)
        _build
        ;;
    test)
        _test
        ;;
    api)
        # Start API only (useful for development)
        _ensure_deps
        STEPWISE_DB="$DB_PATH" STEPWISE_TEMPLATES="$TEMPLATES_DIR" STEPWISE_PORT="$API_PORT" \
            STEPWISE_RELOAD=true uv run python -m stepwise.server
        ;;
    web)
        # Start web only (useful for development)
        _ensure_deps
        cd web && npx vite --port "$WEB_PORT" --host
        ;;
    help|--help|-h)
        echo "Usage: ./run <command>"
        echo ""
        echo "Commands:"
        echo "  start     Start API + web dev server"
        echo "  stop      Stop all services"
        echo "  restart   Restart all services"
        echo "  status    Show service status"
        echo "  build     Build web app for production"
        echo "  test      Run all tests (Python + web)"
        echo "  api       Start API only (with reload)"
        echo "  web       Start web dev server only"
        echo ""
        echo "Environment:"
        echo "  STEPWISE_PORT       API port (default: 8340)"
        echo "  STEPWISE_WEB_PORT   Web port (default: 5173)"
        echo "  STEPWISE_DB         SQLite path (default: ./stepwise.db)"
        echo "  STEPWISE_TEMPLATES  Templates dir (default: ./templates/)"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run './run help' for usage"
        exit 1
        ;;
esac
